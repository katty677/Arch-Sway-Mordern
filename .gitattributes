# Normalize all text files to LF in the repository
* text=auto eol=lf

# Force LF for Linux shell scripts and config files (must never be CRLF)
*.sh        text eol=lf
*.fish      text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.jsonc     text eol=lf
*.css       text eol=lf
*.json      text eol=lf
config      text eol=lf

# Binary files - never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
